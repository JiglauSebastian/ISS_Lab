<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.slim.ui.AdminDashboardController"
            styleClass="root-pane" prefWidth="1100" prefHeight="700">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label text="📚 SLIM" styleClass="top-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="adminNameLabel" styleClass="top-bar-user"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger-small"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" spacing="4" prefWidth="190">
            <padding><Insets top="20" right="10" bottom="20" left="10"/></padding>
            <Label text="NAVIGATION" styleClass="sidebar-section-label"/>
            <Button text="📖  Catalog" onAction="#showCatalog" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button text="👥  Users" onAction="#showUsers" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button text="🔄  Rentals" onAction="#showRentals" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button text="📥  Import Books" onAction="#showImport" styleClass="sidebar-btn" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <Label text="Select a section from the menu." styleClass="placeholder-label"/>
        </StackPane>
    </center>

</BorderPane>
